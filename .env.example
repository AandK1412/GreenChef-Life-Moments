# Copy to .env and fill in to enable the Claude (Anthropic) classifier backend.
# Without a key, the pipeline automatically uses the offline heuristic backend.

ANTHROPIC_API_KEY=

# Backend: auto | anthropic | heuristic   (default: auto)
LIFE_MOMENTS_BACKEND=auto

# Model selection (Section IX.3 of the report).
# Routine classification runs on Sonnet; escalations are reserved for Opus.
LIFE_MOMENTS_MODEL=claude-sonnet-4-6
LIFE_MOMENTS_ESCALATION_MODEL=claude-opus-4-6

# Use the Batch API for bulk/overnight processing (50% cheaper). 1=on, 0=off.
LIFE_MOMENTS_USE_BATCH=1
